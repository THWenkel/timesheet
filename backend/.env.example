# =============================================================================
# backend/.env.example
#
# Environment variable template for the Timesheet backend.
#
# Copy this file to .env and fill in the values:
#   copy .env.example .env
#
# The .env file is git-ignored — never commit secrets to source control.
#
# ⚠️  ALL values marked with TODO must be changed before production deployment.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Database — Microsoft SQL Server
# ─────────────────────────────────────────────────────────────────────────────

# SQL Server hostname or IP address
DB_SERVER=dbserver01

# Target database name
DB_NAME=WiTERP

# SQL Server authentication — login username
# ⚠️  TODO: Replace 'sa' with a dedicated least-privilege SQL account before go-live
DB_USER=sa

# SQL Server authentication — login password
# ⚠️  TODO: Use a secrets manager (Azure Key Vault, etc.) instead of a .env file in production
DB_PASSWORD=your_password_here

# ODBC Encrypt setting — 'no' is required for SQL Server 2012 without TLS
# ⚠️  TODO: Change to 'yes' and configure a valid TLS certificate before production
DB_ENCRYPT=no

# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────

# Set to true for verbose SQL logging (development only)
DEBUG=false

# ─────────────────────────────────────────────────────────────────────────────
# Authentication (v2+ — not active in v1)
# ─────────────────────────────────────────────────────────────────────────────

# Set to true to enforce JWT authentication (requires full auth implementation)
# ⚠️  TODO: Set to true and implement auth before going to production
AUTH_ENABLED=false

# JWT signing secret — must be a long random string in production
# ⚠️  TODO: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-before-production
