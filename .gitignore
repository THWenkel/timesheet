# =============================================================================
# Timesheet Project — .gitignore
# Mixed Python (backend) + TypeScript/React (frontend) project
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
backend/.venv/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# dotenv / secrets
.env
.env.local
.env.*.local
!.env.example

# Type checking
.pyright/
pyrightconfig.json.bak

# Ruff cache
.ruff_cache/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# pytest
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
*.cover

# Jupyter
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Alembic
# -----------------------------------------------------------------------------
# Keep alembic dir but ignore local override files
alembic/versions/__pycache__/

# -----------------------------------------------------------------------------
# Node / Frontend
# -----------------------------------------------------------------------------
node_modules/
frontend/node_modules/

# Build output
frontend/dist/
frontend/build/
dist/

# Vite
.vite/
frontend/.vite/

# npm / yarn / pnpm lockfile variants (keep package-lock.json)
yarn.lock
pnpm-lock.yaml
.pnpm-store/

# TypeScript build info
*.tsbuildinfo
frontend/*.tsbuildinfo

# Vitest coverage
frontend/coverage/

# Generated API types (regenerated from OpenAPI schema at runtime)
frontend/src/api/generated.ts

# -----------------------------------------------------------------------------
# IDE / Editor
# -----------------------------------------------------------------------------
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# Keep .vscode/extensions.json for recommended extensions
!.vscode/extensions.json

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.temp
